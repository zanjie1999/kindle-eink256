        <item name="android:gravity">center</item>
        <item name="android:background">?nis_card_button_background_color</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/nis_buy_button_height</item>
        <item name="android:minWidth">@dimen/nis_buy_button_width</item>
    </style>
</resources>
