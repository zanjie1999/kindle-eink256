<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:orientation="vertical" android:id="@id/notifications_screen" android:background="@color/brochure_layout_background" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:custom="http://schemas.android.com/apk/res-auto">
    <androidx.viewpager.widget.ViewPager android:id="@id/pager" android:layout_width="wrap_content" android:layout_height="fill_parent" android:layout_alignParentTop="true"
      xmlns:android="http://schemas.android.com/apk/res/android" />
    <RelativeLayout android:id="@id/pagerLayout" android:layout_width="fill_parent" android:layout_height="fill_parent">
        <FrameLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_centerHorizontal="true">
            <com.amazon.kcp.reader.ui.DotPageIndicator android:layout_gravity="center_horizontal" android:id="@id/brochurePageIndicator" android:layout_width="wrap_content" android:layout_height="@dimen/brochure_page_indicator_height" android:layout_marginTop="@dimen/brochure_page_indicator_margin_top" android:importantForAccessibility="no" custom:indicatorSpacing="@dimen/brochure_page_indicator_spacing" custom:indicatorType="resource" custom:resourceActive="@drawable/ic_circle_blue" custom:resourceInactive="@drawable/ic_circle_grey" />
