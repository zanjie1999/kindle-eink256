        <Button android:id="@id/shareButton" android:visibility="gone" android:text="@string/brochure_share_button_text" style="@style/brochure_button" />
        <Button android:id="@id/nextButton" android:text="@string/brochure_next_button_text" style="@style/brochure_button" />
    </LinearLayout>
</RelativeLayout>