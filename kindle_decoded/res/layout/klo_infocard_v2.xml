<?xml version="1.0" encoding="utf-8"?>
<com.amazon.klo.infocard.KLOInfoCardView android:id="@id/klo_infocard" style="@style/info_card_v2_container"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent" android:importantForAccessibility="no">
        <RelativeLayout android:importantForAccessibility="no" style="@style/info_card_v2_title_bar">
            <TextView android:id="@id/klo_infocard_title_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/klo_infocard_title_margin_right" android:text="@string/klo_info_card_title_with_colon" android:layout_alignParentLeft="true" android:layout_centerVertical="true" style="@style/info_card_v2_title_text" />
            <TextView android:id="@id/klo_infocard_query_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/klo_infocard_title_label" android:layout_centerVertical="true" style="@style/info_card_v2_title_text" />
        </RelativeLayout>
        <FrameLayout android:id="@id/klo_infocard_content_wrapper" android:importantForAccessibility="no" style="@style/info_card_v2_content_bar">
            <ScrollView android:layout_width="fill_parent" android:layout_height="wrap_content">
                <RelativeLayout android:paddingLeft="@dimen/info_card_v2_content_horizontal_padding" android:paddingTop="@dimen/info_card_v2_content_vertical_padding" android:paddingRight="@dimen/info_card_v2_content_horizontal_padding" android:paddingBottom="@dimen/info_card_v2_content_vertical_padding" android:layout_width="fill_parent" android:layout_height="wrap_content">
                    <TextView android:id="@id/klo_infocard_content_label" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/klo_infocard_content_margin_bottom" android:layout_alignParentTop="true" style="@style/info_card_v2_content_text" />
                    <TextView android:textColorLink="@color/info_card_v2_link_button_text_color_white_mode" android:id="@id/klo_infocard_license_label" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_below="@id/klo_infocard_content_label" android:layout_alignParentBottom="true" style="@style/info_card_v2_content_secondary_text" />
                </RelativeLayout>
            </ScrollView>
        </FrameLayout>
        <RelativeLayout android:orientation="vertical" android:paddingLeft="@dimen/info_card_v2_link_button_bar_horizontal_padding" android:paddingRight="@dimen/info_card_v2_link_button_bar_horizontal_padding" android:importantForAccessibility="no" style="@style/info_card_v2_button_bar">
            <TextView android:id="@id/klo_infocard_open_button" android:text="@string/klo_info_card_v2_open_button_text" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/info_card_v2_link_button_bold" />
            <TextView android:id="@id/klo_infocard_source_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/klo_glossary_definition" android:layout_alignParentLeft="true" android:layout_centerVertical="true" style="@style/info_card_v2_caption_button_text" />
        </RelativeLayout>
    </LinearLayout>
</com.amazon.klo.infocard.KLOInfoCardView>