<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout style="@style/bookwizard_page"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <include android:id="@id/bookwizard_header_layout" layout="@layout/bookwizard_header" />
    <include android:id="@id/bookwizard_footer_layout" layout="@layout/bookwizard_footer" />
    <include android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_above="@id/bookwizard_footer_layout" android:layout_below="@id/bookwizard_header_layout" android:layout_centerHorizontal="true" layout="@layout/bookwizard_spinner" />
    <ScrollView android:id="@id/ratings_content_pane" android:visibility="gone" android:scrollbars="none" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_above="@id/bookwizard_footer_layout" android:layout_below="@id/bookwizard_header_layout">
        <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent">
            <com.amazon.bookwizard.ui.view.ExpandableHeightGridView android:id="@id/ratings_shoveler_grid" android:paddingLeft="0.0dip" android:paddingRight="0.0dip" android:layout_width="fill_parent" android:layout_height="fill_parent" android:numColumns="1" android:isScrollContainer="false" />
            <include android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/bookwizard_goodreads_padding" layout="@layout/bookwizard_goodreads_logo" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>