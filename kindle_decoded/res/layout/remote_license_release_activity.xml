<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:background="?rlr_background_color" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <ProgressBar android:id="@id/rlr_remove_consumptions_progress" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="@dimen/rlr_release_progress_bar_height" android:layout_marginTop="@dimen/top_bar_height" android:max="100" style="?android:progressBarStyleHorizontal" />
    <include layout="@layout/remote_license_release_top_bar" />
