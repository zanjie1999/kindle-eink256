<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <include android:id="@id/top_border" layout="@layout/startactions_component_divider" />
    <TextView android:textAppearance="@style/anyactions_amazon_text_regular" android:textStyle="bold" android:ellipsize="end" android:id="@id/title" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/startactions_xsmall_padding" android:maxLines="@integer/endactions_detail_bubble_title_max_lines" />
    <TextView android:textAppearance="@style/anyactions_amazon_text_small" android:ellipsize="end" android:id="@id/author" android:layout_width="fill_parent" android:layout_height="wrap_content" android:maxLines="@integer/endactions_detail_bubble_author_max_lines" />
    <RelativeLayout android:id="@id/rating_container" android:paddingTop="@dimen/startactions_xsmall_padding" android:paddingBottom="@dimen/startactions_xsmall_padding" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <RatingBar android:orientation="horizontal" android:id="@id/rating_bar" android:visibility="gone" android:saveEnabled="false" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="0.5" android:isIndicator="true" android:layout_alignParentLeft="true" style="?android:ratingBarStyleSmall" />
        <TextView android:textAppearance="@style/anyactions_amazon_text_small" android:id="@id/rating_count" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/startactions_small_padding" android:maxLines="1" android:layout_toRightOf="@id/rating_bar" />
        <Button android:id="@id/see_in_store" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/startactions_widget_bookgrid_seeinstore_vertical_padding" android:minHeight="0.0dip" android:text="@string/startactions_widget_see_in_store" android:layout_below="@id/rating_bar" android:layout_alignParentLeft="true" style="@style/startactions_text_button_light_small" />
        <Button android:gravity="center_vertical" android:id="@id/book_grid_share_button" android:background="@drawable/bg_startactions_borderless_button" android:layout_width="wrap_content" android:layout_marginTop="@dimen/startactions_widget_bookgrid_share_vertical_padding" android:layout_marginBottom="@dimen/startactions_widget_bookgrid_share_vertical_padding" android:text="@string/anyactions_widget_share_text" android:drawableRight="@drawable/anyactions_share_button_icon_light" android:drawablePadding="@dimen/startactions_widget_bookgrid_share_icon_padding" android:layout_below="@id/rating_bar" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/startactions_text_button_light_small" />
    </RelativeLayout>
    <ImageView android:id="@id/startactions_ku_badge" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/endactions_ku_badge_small_padding_left" android:layout_marginTop="@dimen/startactions_small_padding" android:layout_marginBottom="@dimen/startactions_small_padding" android:src="@drawable/ic_ku_badge_small_light" />
    <ImageView android:id="@id/startactions_pr_badge" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/endactions_ku_badge_small_padding_left" android:layout_marginTop="@dimen/startactions_small_padding" android:layout_marginBottom="@dimen/startactions_small_padding" android:src="@drawable/ic_pr_badge_small" />
    <TextView android:textAppearance="@style/anyactions_amazon_text_regular" android:ellipsize="end" android:id="@id/description" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/startactions_xsmall_padding" android:layout_marginBottom="@dimen/startactions_small_padding" android:maxLines="4" android:textDirection="firstStrong" android:textAlignment="textStart" />
    <View android:id="@id/null_description_padding" android:layout_width="fill_parent" android:layout_height="@dimen/startactions_widget_book_grid_null_description_padding" />
    <LinearLayout android:orientation="vertical" android:id="@id/buttons" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/startactions_xsmall_padding">
        <Button android:textAppearance="@style/anyactions_amazon_text_roman_small" android:id="@id/buy_now" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="wrap_content" android:minHeight="@dimen/startactions_button_height" android:text="@string/endactions_buy_now" />
        <LinearLayout android:orientation="horizontal" android:id="@id/failure_view" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ImageView android:gravity="top" android:id="@id/failure_asset" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/endactions_small_padding" android:layout_marginRight="@dimen/endactions_medium_padding" android:src="@drawable/startactions_failure_triangle" />
            <Button android:ellipsize="end" android:gravity="center|left" android:id="@id/purchase_failure" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/endactions_widget_buy_fail" style="@style/startactions_text_button_light_small" />
        </LinearLayout>
        <Button android:gravity="center|left" android:id="@id/cancel_purchase" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/endactions_widget_buy_cancel" style="@style/startactions_text_button_light_small" />
    </LinearLayout>
    <include android:id="@id/bottom_border" layout="@layout/startactions_component_divider" />
</LinearLayout>