            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
            <ImageView android:layout_gravity="center_vertical" android:id="@id/buy_success_onetap_checkmark" android:focusable="false" android:visibility="gone" android:clickable="false" android:layout_width="@dimen/endactions_text_button_height_small" android:layout_height="@dimen/endactions_text_button_height_small" android:scaleType="centerInside" android:layout_marginStart="@dimen/endactions_space_between_buttons" android:layout_marginEnd="@dimen/endactions_space_between_buttons" />
            <TextView android:textAppearance="@style/anyactions_amazon_text_small" android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@id/buy_success_onetap_toast" android:background="@drawable/bg_startactions_borderless_button" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/endactions_space_between_buttons" android:layout_marginBottom="@dimen/endactions_space_between_buttons" android:minHeight="16.0dip" android:text="@string/endactions_onetap_purchase_success" />
