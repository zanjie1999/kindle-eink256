            <ImageView android:gravity="top" android:id="@id/failure_asset_one_tap" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/endactions_small_padding" android:layout_marginRight="@dimen/endactions_medium_padding" android:src="@drawable/endactions_failure_triangle" />
            <Button android:gravity="center|left" android:id="@id/purchase_failure_one_tap" android:visibility="gone" android:text="@string/endactions_onetap_order_processing_fail" style="@style/startactions_text_button_light_small" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>