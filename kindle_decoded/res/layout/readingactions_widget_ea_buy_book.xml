                <ImageView android:id="@id/endactions_pr_badge_one_tap" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/endactions_xsmall_padding" android:layout_marginTop="@dimen/endactions_xsmall_padding" android:layout_marginBottom="@dimen/endactions_xsmall_padding" android:src="@drawable/ic_pr_badge_small" />
