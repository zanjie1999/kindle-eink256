<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.appcompat.widget.Toolbar android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" android:id="@id/webview_toolbar" android:background="@color/actionbar_text_white_normal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_alignParentTop="true" />
    <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@id/webview_progress_bar" android:background="@color/actionbar_text_white_normal" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_below="@id/webview_toolbar">
        <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:indeterminateTint="@color/color_accent_dark" style="?android:progressBarStyleLarge" />
    </LinearLayout>
    <WebView android:id="@id/webview" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_below="@id/webview_toolbar" />
</RelativeLayout>