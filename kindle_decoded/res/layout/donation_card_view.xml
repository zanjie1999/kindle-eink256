<?xml version="1.0" encoding="utf-8"?>
<com.amazon.kcp.home.ui.HomeCardView android:layout_width="fill_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <RelativeLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/home_card_margin" android:layout_marginStart="@dimen/home_card_margin" android:layout_marginEnd="@dimen/home_card_margin">
            <com.amazon.android.ui.UiFontTextView android:textAppearance="@style/Ruby.TextAppearance.Header1" android:id="@id/donation_title" android:tag="TEXT_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginEnd="@dimen/home_donation_text_margin_end" android:layout_alignParentStart="true" />
            <ImageView android:id="@id/donation_close_button" android:tag="BUTTON_1" android:layout_width="@dimen/home_donation_close_button_size" android:layout_height="@dimen/home_donation_close_button_size" android:layout_centerVertical="true" android:contentDescription="@string/kre_home_dismiss_button" android:layout_alignParentEnd="true" />
        </RelativeLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/home_donation_content_margin_top" android:layout_marginStart="@dimen/home_card_margin" android:layout_marginEnd="@dimen/home_card_margin">
            <ImageView android:layout_gravity="center_vertical" android:id="@id/donation_body_image" android:tag="THEMED_IMAGE_1" android:layout_width="@dimen/home_donation_image_size" android:layout_height="@dimen/home_donation_image_size" android:layout_marginEnd="@dimen/home_donation_image_margin_end" />
            <com.amazon.android.ui.UiFontTextView android:textAppearance="@style/Ruby.TextAppearance.Body.Italic" android:id="@id/donation_body" android:tag="TEXT_2" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
        <include layout="@layout/home_card_footer" />
    </LinearLayout>
</com.amazon.kcp.home.ui.HomeCardView>