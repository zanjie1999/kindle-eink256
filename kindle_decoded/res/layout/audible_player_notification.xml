<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:background="@android:color/black" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:id="@id/play_pause_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true"
      xmlns:android="http://schemas.android.com/apk/res/android">
        <ImageView android:id="@id/notification_play_button" android:background="@android:color/transparent" android:padding="@dimen/notification_medium_padding" android:layout_width="@dimen/notification_large_icon_width" android:layout_height="@dimen/notification_large_icon_height" android:src="@drawable/notification_play" android:scaleType="center" android:contentDescription="@string/accessibility_player_notification_play_description" />
        <ImageView android:id="@id/notification_pause_button" android:background="@android:color/transparent" android:padding="@dimen/notification_medium_padding" android:layout_width="@dimen/notification_large_icon_width" android:layout_height="@dimen/notification_large_icon_height" android:src="@drawable/notification_pause" android:scaleType="center" android:contentDescription="@string/accessibility_player_notification_pause_description" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/notification_cancel_button" android:layout_toRightOf="@id/play_pause_layout" android:layout_centerVertical="true">
        <RelativeLayout android:id="@id/notification_content_section" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_marginLeft="@dimen/notification_medium_margin" android:layout_marginTop="@dimen/notification_small_margin">
            <TextView android:ellipsize="end" android:id="@id/notification_title_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" style="@style/PlayerNotificationTextMedium" />
            <TextView android:ellipsize="end" android:id="@id/notification_author_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:layout_below="@id/notification_title_text" android:layout_alignLeft="@id/notification_title_text" android:layout_alignStart="@id/notification_title_text" style="@style/PlayerNotificationTextSmall" />
            <TextView android:ellipsize="end" android:id="@id/notification_narrated_by_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:layout_below="@id/notification_author_text" android:layout_alignLeft="@id/notification_title_text" android:layout_alignStart="@id/notification_title_text" style="@style/PlayerNotificationTextSmall" />
        </RelativeLayout>
    </LinearLayout>
    <ImageView android:id="@id/notification_cancel_button" android:padding="@dimen/notification_medium_padding" android:layout_width="@dimen/notification_large_icon_width" android:layout_height="@dimen/notification_large_icon_height" android:src="@drawable/notification_close" android:scaleType="centerInside" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:contentDescription="@string/accessibility_player_notification_dismiss_description" android:layout_alignParentEnd="true" />
</RelativeLayout>