<?xml version="1.0" encoding="utf-8"?>
<merge
  xmlns:android="http://schemas.android.com/apk/res/android">
    <RelativeLayout android:id="@id/deck_list_item" android:background="?fc_secondary_bg_color" android:layout_width="fill_parent" android:layout_height="@dimen/fc_deck_list_item_height">
        <View android:id="@id/overlay" android:background="@android:color/transparent" android:layout_width="fill_parent" android:layout_height="fill_parent" android:alpha="0.0" />
        <RelativeLayout android:id="@id/deck_list_item_body" android:background="?fc_bg_deck_list_item" android:layout_width="fill_parent" android:layout_height="fill_parent" style="@style/fc_deck_list_item_body">
            <RelativeLayout android:id="@id/deck_list_item_info_container" android:paddingRight="@dimen/fc_deck_list_item_padding_sides" android:layout_width="wrap_content" android:layout_height="fill_parent" android:layout_toLeftOf="@id/deck_list_item_progress_container" android:layout_alignParentLeft="true" android:layout_alignParentTop="true" android:layout_toStartOf="@id/deck_list_item_progress_container" android:layout_alignParentStart="true">
                <com.amazon.kedu.flashcards.views.ReaderContentTextView android:textColor="?fc_textColorPrimaryStateful" android:id="@id/deck_name" android:layout_alignParentTop="true" android:textDirection="firstStrong" style="@style/fc_deck_list_primary_label" />
                <TextView android:id="@id/deck_card_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentLeft="true" android:layout_alignParentBottom="true" style="@style/fc_deck_list_meta_label" />
                <TextView android:id="@id/deck_last_edited" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/deck_card_count" android:layout_alignParentBottom="true" style="@style/fc_deck_list_meta_label.last_edited" />
            </RelativeLayout>
            <RelativeLayout android:id="@id/deck_list_item_progress_container" android:layout_width="wrap_content" android:layout_height="fill_parent" android:layout_alignParentRight="true" android:layout_alignParentEnd="true">
                <ProgressBar android:id="@id/progress_bar" android:visibility="invisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" style="@style/fc_deck_list_item_progress_bar" />
                <TextView android:textColor="?fc_textColorPrimaryStateful" android:id="@id/deck_progress_percent" android:visibility="invisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_centerHorizontal="true" style="@style/fc_deck_list_primary_label" />
                <TextView android:id="@id/deck_progress_correct_label" android:visibility="invisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/fc_deck_list_correct" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" style="@style/fc_deck_list_meta_label" />
            </RelativeLayout>
        </RelativeLayout>
        <View android:id="@id/deck_list_item_divider" android:layout_width="fill_parent" android:layout_height="@dimen/fc_deck_list_divider_height" android:layout_alignParentBottom="true" style="@style/fc_deck_list_item_divider" />
    </RelativeLayout>
    <RelativeLayout android:id="@id/flashcard_deleted_view" android:layout_width="fill_parent" android:layout_height="@dimen/fc_deck_list_item_height" style="@style/fc_deck_list_item_body">
        <TextView android:textColor="?fc_textColorPrimaryStateful" android:id="@id/deleted_message" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/fc_deck_deleted_text" android:layout_toLeftOf="@id/undo_delete_button" android:layout_alignParentLeft="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/undo_delete_button" android:layout_alignParentStart="true" style="@style/fc_deck_list_primary_label" />
        <Button android:textSize="@dimen/fc_font_micro_text_size" android:id="@id/undo_delete_button" android:paddingLeft="@dimen/fc_deck_list_undo_button_padding_sides" android:paddingTop="@dimen/fc_deck_list_undo_button_padding_ends" android:paddingRight="@dimen/fc_deck_list_undo_button_padding_sides" android:paddingBottom="@dimen/fc_deck_list_undo_button_padding_ends" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/fc_undo_deleted_flashcard_button_text" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:layout_alignParentEnd="true" style="@style/fc_button.neutral" />
    </RelativeLayout>
</merge>