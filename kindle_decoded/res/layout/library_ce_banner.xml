<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:id="@id/library_ce_banner" android:background="@color/amznDarkGrey" android:visibility="gone" android:layout_width="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
