<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" style="@style/more_menu_item_container">
        <ImageView android:id="@id/item_icon" style="@style/more_menu_item_icon" />
        <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:id="@id/item_title" style="@style/more_menu_item_primary_text" />
            <TextView android:id="@id/item_subtitle" android:visibility="gone" style="@style/more_menu_item_secondary_text" />
        </LinearLayout>
        <ImageView android:id="@id/secondary_icon" android:visibility="gone" style="@style/more_menu_item_secondary_icon" />
    </LinearLayout>
    <View style="@style/more_menu_item_divider" />
</LinearLayout>