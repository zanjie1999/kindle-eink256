    <TextView android:id="@id/sample_bar_title" android:paddingTop="@dimen/sample_bar_title_text_top_padding_nln" android:paddingRight="@dimen/sample_bar_text_padding_right_nln" android:paddingBottom="@dimen/sample_bar_title_text_bottom_padding_nln" android:focusable="true" android:layout_toLeftOf="@id/right_content" android:layout_alignParentLeft="true" style="@style/upsell_bar_text_title_nln" />
