        <FrameLayout android:id="@id/xray_carousel_context_footer" android:layout_width="fill_parent" android:layout_height="@dimen/xray_size_carousel_context_footer_height" android:layout_marginLeft="@dimen/xray_padding_related_entity_gutter" android:layout_marginTop="@dimen/xray_padding_carousel_context_top" android:layout_marginRight="@dimen/xray_padding_related_entity_gutter" android:layout_marginBottom="@dimen/xray_padding_carousel_context_bottom" android:layout_alignParentBottom="true">
