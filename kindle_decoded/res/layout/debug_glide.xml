<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <EditText android:id="@id/client_id" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="default" android:hint="Client ID" />
    <EditText android:id="@id/get_offers_asin" android:layout_width="fill_parent" android:layout_height="wrap_content" android:hint="ASIN" />
    <Button android:id="@id/get_offers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get Offers" />
    <Spinner android:id="@id/offers_spinner" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content">
        <Button android:id="@id/show_offer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get Detail" />
        <Button android:id="@id/buy_offer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Buy Offer" />
        <Button android:id="@id/borrow_offer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Borrow Offer" />
        <Button android:id="@id/corrupt_offer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Corrupt Offer" />
    </LinearLayout>
    <TextView android:id="@id/details" android:layout_width="fill_parent" android:layout_height="wrap_content" />
    <Spinner android:id="@id/acquired_offers_spinner" android:visibility="invisible" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <EditText android:id="@id/order_id" android:layout_width="fill_parent" android:layout_height="wrap_content" android:hint="Order ID" />
    <EditText android:id="@id/order_item_id" android:layout_width="fill_parent" android:layout_height="wrap_content" android:hint="Order Item ID" />
    <Button android:id="@id/cancel_offer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancel Offer" />
    <Button android:id="@id/return_asin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Return Asin" />
</LinearLayout>