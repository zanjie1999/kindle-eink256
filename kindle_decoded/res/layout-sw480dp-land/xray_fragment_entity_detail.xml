<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:pkg="http://schemas.android.com/apk/res-auto">
    <include layout="@layout/xray_inline_progress" />
    <include layout="@layout/xray_inline_error" />
    <RelativeLayout android:orientation="horizontal" android:id="@id/xray_content" android:layout_width="fill_parent" android:layout_height="fill_parent">
        <com.amazon.xray.ui.widget.TabView android:id="@id/xray_tabs" android:layout_width="wrap_content" android:layout_height="fill_parent" pkg:xray_content_view="@id/xray_tab_content" pkg:xray_orientation="vertical" />
        <View android:id="@id/xray_separator" android:layout_width="@dimen/xray_size_separator_thickness" android:layout_height="fill_parent" android:layout_marginTop="@dimen/xray_padding_tab_separator_vertical" android:layout_toRightOf="@id/xray_tabs" />
        <FrameLayout android:id="@id/xray_description_container" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_toRightOf="@id/xray_separator">
            <com.amazon.xray.ui.widget.EnhancedTextView android:textAppearance="@style/xray_amazon_text_light_regular" android:id="@id/xray_entity_desc" android:background="@drawable/bg_xray_borderless_view" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/xray_padding_gutter" android:layout_marginTop="@dimen/xray_padding_vertical" android:layout_marginRight="@dimen/xray_padding_gutter" android:layout_marginBottom="@dimen/xray_padding_description_bottom" android:lines="@integer/xray_description_max_lines" />
        </FrameLayout>
        <FrameLayout android:id="@id/xray_tab_content" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_toRightOf="@id/xray_separator" android:layout_below="@id/xray_description_container" android:layout_alignParentRight="true" android:layout_alignParentBottom="true" />
    </RelativeLayout>
</FrameLayout>