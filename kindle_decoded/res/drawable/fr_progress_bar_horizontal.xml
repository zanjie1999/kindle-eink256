<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <nine-patch android:src="@drawable/progress_alpha" android:tint="@color/text_secondary_dark" android:alpha="?android:disabledAlpha" />
    </item>
    <item android:id="@android:id/secondaryProgress">
        <scale android:scaleWidth="100%">
            <nine-patch android:src="@drawable/progress_alpha" android:tint="@color/primary_light" android:alpha="?android:disabledAlpha" />
        </scale>
    </item>
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%">
            <nine-patch android:src="@drawable/progress_alpha" android:tint="@color/primary_light" />
        </scale>
    </item>
</layer-list>