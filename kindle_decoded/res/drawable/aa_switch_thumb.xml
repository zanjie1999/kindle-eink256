            <item android:duration="15">
                <nine-patch android:src="@drawable/aa_btn_switch_to_on_012" android:tint="?android:colorControlActivated" />
            </item>
        </animation-list>
    </transition>
    <transition android:toId="@id/off" android:fromId="@id/on">
