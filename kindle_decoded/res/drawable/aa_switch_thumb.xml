<?xml version="1.0" encoding="utf-8"?>
<animated-selector android:constantSize="true"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:id="@id/off">
        <nine-patch android:src="@drawable/aa_btn_switch_to_on_001" android:tint="?android:colorControlNormal" android:alpha="0.3" />
    </item>
    <item android:state_checked="true" android:id="@id/on">
