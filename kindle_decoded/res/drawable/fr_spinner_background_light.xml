<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:state_window_focused="true" android:state_enabled="false">
        <layer-list android:paddingMode="stack">
            <item>
                <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlNormal" android:alpha="?android:disabledAlpha" />
            </item>
            <item>
                <nine-patch android:src="@drawable/spinner_am_activated" android:tint="?colorControlActivated" />
            </item>
        </layer-list>
    </item>
    <item android:state_enabled="false">
        <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlNormal" android:alpha="?android:disabledAlpha" />
    </item>
    <item android:state_focused="true" android:state_window_focused="true" android:state_pressed="true">
        <layer-list android:paddingMode="stack">
            <item>
                <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlActivated" />
            </item>
            <item>
                <nine-patch android:src="@drawable/spinner_am_activated" android:tint="?colorControlActivated" />
            </item>
        </layer-list>
    </item>
    <item android:state_focused="true" android:state_window_focused="true">
        <layer-list android:paddingMode="stack">
            <item>
                <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlNormal" />
            </item>
            <item>
                <nine-patch android:src="@drawable/spinner_am_activated" android:tint="?colorControlActivated" />
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlActivated" />
    </item>
    <item>
        <nine-patch android:src="@drawable/spinner_am_alpha_light" android:tint="?colorControlNormal" />
    </item>
</selector>