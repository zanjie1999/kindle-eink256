<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:state_pressed="true">
        <inset android:drawable="@drawable/eink_checkedtextview_checkmark_pressed" android:insetLeft="@dimen/e3os_checkedtextview_leftpadding" android:insetRight="@dimen/e3os_checkedtextview_rightpadding" android:insetTop="@dimen/e3os_checkedtextview_toppadding" android:insetBottom="@dimen/e3os_checkedtextview_bottompadding" />
        <color android:color="@color/eink_white" />
    </item>
    <item android:state_checked="true" android:state_pressed="false">
        <inset android:drawable="@drawable/eink_checkedtextview_checkmark" android:insetLeft="@dimen/e3os_checkedtextview_leftpadding" android:insetRight="@dimen/e3os_checkedtextview_rightpadding" android:insetTop="@dimen/e3os_checkedtextview_toppadding" android:insetBottom="@dimen/e3os_checkedtextview_bottompadding" />
        <color android:color="@color/eink_white" />
    </item>
    <item>
        <shape android:shape="rectangle">
            <size android:height="@dimen/e3os_empty_height" android:width="@dimen/e3os_empty_width" />
        </shape>
    </item>
</selector>