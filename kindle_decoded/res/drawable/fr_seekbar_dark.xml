<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:drawable="@drawable/scrubber_track_dark" />
    <item>
        <layer-list
          xmlns:android="http://schemas.android.com/apk/res/android">
            <item android:id="@android:id/background" android:drawable="@drawable/scrubber_track_dark" />
            <item android:id="@android:id/secondaryProgress">
                <scale android:drawable="@drawable/scrubber_secondary_dark" android:scaleWidth="100%" />
            </item>
            <item android:id="@android:id/progress">
                <scale android:drawable="@drawable/scrubber_primary_dark" android:scaleWidth="100%" />
            </item>
        </layer-list>
    </item>
</selector>