<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ra_light_grey" />
        </shape>
    </item>
    <item android:top="@dimen/readingactions_blurb_card_box_top_distance" android:right="@dimen/readingactions_blurb_card_box_thickness">
        <shape android:shape="rectangle">
            <size android:height="@dimen/readingactions_blurb_card_box_rectangle_height" />
            <solid android:color="@color/white" />
        </shape>
    </item>
    <item android:top="@dimen/readingactions_blurb_card_box_bottom_distance" android:right="@dimen/readingactions_blurb_card_box_thickness">
        <shape android:shape="rectangle">
            <size android:height="@dimen/readingactions_blurb_card_box_rectangle_height" />
            <solid android:color="@color/ra_light_grey" />
        </shape>
    </item>
    <item android:left="@dimen/readingactions_blurb_card_box_thickness" android:top="@dimen/readingactions_blurb_card_box_thickness" android:right="@dimen/readingactions_blurb_card_box_thickness" android:bottom="@dimen/readingactions_blurb_card_box_thickness">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
        </shape>
    </item>
</layer-list>